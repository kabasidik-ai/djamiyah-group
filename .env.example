# ============================================================
# VARIABLES D'ENVIRONNEMENT — Groupe Djamiyah
# ============================================================
# Copier ce fichier en .env.local et remplir les valeurs

# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Token d'accès personnel Supabase (pour MCP/CLI uniquement, jamais en production)
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# CHAPCHAP (Paiement)
# ============================================================
CHAPCHAP_API_KEY_TEST=test_xxxxxxxxxxxxxxxxxxxxx
CHAPCHAP_API_KEY_PRODUCTION=live_xxxxxxxxxxxxxxxxxxxxx
CHAPCHAP_HMAC_SECRET=your_hmac_secret_here
CHAPCHAP_BASE_URL=https://api.chapchappay.com

# ============================================================
# SITE
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URLs de callback ChapChap
CHAPCHAP_NOTIFY_URL=http://localhost:3000/api/chapchap/notify
CHAPCHAP_RETURN_URL=http://localhost:3000/reservation/success

# ============================================================
# GOHIGHLEVEL — Conversation AI (OBLIGATOIRE pour le chatbot)
# ============================================================

# API Token GHL — Obtenir dans GHL > Settings > Integrations > API Keys
# ⚠️ JAMAIS de préfixe NEXT_PUBLIC_ — côté serveur uniquement
GHL_API_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Location ID du sous-compte "Maison Blanche de Coyah"
# GHL > Sub-Account > Settings > Business Profile > Location ID
GHL_LOCATION_ID=a5wcdv6hapHNnLA9xnl4

# Agent ID Salematou (Conversation AI)
# GHL > Conversation AI > Agents > Salematou > ... > Copy Agent ID
GHL_CONVERSATION_AI_AGENT_ID=ryIJEDRGuVTfu5x6uHVE

# ============================================================
# GOHIGHLEVEL — OAuth (optionnel, si intégration OAuth utilisée)
# ============================================================
GHL_CLIENT_ID=your_ghl_client_id
GHL_CLIENT_SECRET=your_ghl_client_secret
GHL_REDIRECT_URI=http://localhost:3000/api/auth/ghl/callback

# ============================================================
# NOTES
# ============================================================
# - Ne jamais commiter .env.local dans Git
# - SUPABASE_SERVICE_ROLE_KEY : uniquement côté serveur
# - GHL_API_TOKEN : uniquement côté serveur (pas de NEXT_PUBLIC_)
# - Mode test ChapChap : utiliser CHAPCHAP_API_KEY_TEST
# - Mode production : utiliser CHAPCHAP_API_KEY_PRODUCTION
#
# ── Variables à configurer dans Vercel Dashboard ──────────────
# Dashboard → djamiyah-group → Settings → Environment Variables
# Ajouter toutes les variables ci-dessus pour l'env "Production"
# Redéployer après chaque modification de variable
