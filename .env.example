# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVEUR UNIQUEMENT — jamais exposé côté client

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production → https://djamiyah-group.vercel.app

# ─── ChapChap Payment (gateway africain) ──────────────────────────────────────
# Get from: https://chapchappay.com → Dashboard → API Keys
CHAPCHAP_API_KEY_TEST=
CHAPCHAP_API_KEY_PRODUCTION=
CHAPCHAP_HMAC_SECRET=               # Secret HMAC pour vérification webhooks
CHAPCHAP_BASE_URL=https://chapchappay.com/api

# ─── ChapChap URLs de callback ────────────────────────────────────────────────
# Développement local :
CHAPCHAP_NOTIFY_URL=http://localhost:3000/api/payment/webhook
CHAPCHAP_RETURN_URL=http://localhost:3000/reservation/success
CHAPCHAP_CANCEL_URL=http://localhost:3000/reservation
# Production Vercel → remplacer localhost:3000 par https://djamiyah-group.vercel.app

# ─── Supabase MCP (accès Cline / Claude — local uniquement) ──────────────────
# Get from: https://app.supabase.com → Account → Access Tokens
# NE PAS renseigner en production
SUPABASE_ACCESS_TOKEN=
