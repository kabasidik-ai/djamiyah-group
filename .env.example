# ==============================================================
# Variables d'environnement — Groupe Djamiyah
# Copiez ce fichier en .env.local pour le développement local
# NE JAMAIS committer .env.local sur Git
# ==============================================================

# ── Site ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production : https://djamiyah-group.vercel.app

# ── Supabase ───────────────────────────────────────────────────
# https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SERVEUR UNIQUEMENT

# ── GHL OAuth 2.0 (Developer Marketplace) ─────────────────────
# 1. Créez une app sur https://marketplace.gohighlevel.com/
# 2. Type : "Sub-Account" (accès location-level)
# 3. Redirect URI : https://djamiyah-group.vercel.app/api/auth/ghl/callback
# 4. Copiez Client ID et Client Secret ci-dessous
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_OAUTH_REDIRECT_URI=https://djamiyah-group.vercel.app/api/auth/ghl/callback
# Local : http://localhost:3000/api/auth/ghl/callback

# ── GHL Config (récupérés via /api/ghl/locations et /api/ghl/agents) ──
# Étape 1 — Autorisez l'app : GET /api/auth/ghl/authorize
# Étape 2 — Listez les locations : GET /api/ghl/locations
# Étape 3 — Copiez votre location_id ci-dessous
GHL_LOCATION_ID=a5wcdv6hapHNnLA9xnl4

# Étape 4 — Listez les agents : GET /api/ghl/agents
# Étape 5 — Copiez l'ID du bot Concierge IA ci-dessous
GHL_CONVERSATION_AI_AGENT_ID=

# GHL Company ID (optionnel — pour lister toutes les locations)
GHL_COMPANY_ID=

# ── GHL Legacy (migration en cours — à supprimer après OAuth) ──
# Utilisé en fallback tant que OAuth n'est pas configuré
GHL_PRIVATE_TOKEN=

# ── Concierge Salematou ────────────────────────────────────────
# URL de la photo de Salematou (HTTPS, format carré recommandé)
# Alternative : utiliser PUT /api/admin/avatar (sans redéploiement)
SALEMATOU_AVATAR_URL=

# ── Administration ─────────────────────────────────────────────
# Clé secrète pour les endpoints /api/admin/* (header x-admin-key)
# Générer : openssl rand -hex 32
ADMIN_SECRET_KEY=

# ── ChapChap Payment ───────────────────────────────────────────
# https://chapchappay.com → Dashboard → API Keys
CHAPCHAP_API_KEY_TEST=
CHAPCHAP_API_KEY_PRODUCTION=
CHAPCHAP_HMAC_SECRET=
CHAPCHAP_BASE_URL=https://chapchappay.com/api
CHAPCHAP_NOTIFY_URL=http://localhost:3000/api/payment/webhook
CHAPCHAP_RETURN_URL=http://localhost:3000/reservation/success
CHAPCHAP_CANCEL_URL=http://localhost:3000/reservation
